# Teacher's Journal Backend - Environment Configuration
# Скопируй этот файл в .env и заполни реальные значения

# ============= DATABASE =============
# Учетные данные для подключения к MySQL
DATABASE_USER=teacher_app
DATABASE_PASSWORD=my_secure_password
# Локальная разработка: 127.0.0.1 | Docker деплой: mysql (имя docker-сервиса)
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=teacher_journal
# Только для Docker деплоя — пароль root MySQL контейнера
MYSQL_ROOT_PASSWORD=root_password_change_me

# ============= AUTHENTICATION =============
# Секретный ключ для подписи JWT токенов
# ⚠️ ВАЖНО: В продакшене генерируй безопасный ключ!
# Пример: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_change_me_in_production

# Алгоритм кодирования JWT (HS256 - стандартный)
ALGORITHM=HS256

# Время жизни Access Token (в минутах)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Время жизни Refresh Token (в днях)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============= APPLICATION =============
# Режим отладки (true/false)
DEBUG=false

# ============= CORS =============
# Локальная разработка — оставь как есть
# Docker деплой — замени SERVER_IP_HERE на реальный IP или домен сервера
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://SERVER_IP_HERE"]
